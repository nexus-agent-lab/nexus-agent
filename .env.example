# ==========================================
# Nexus Agent Configuration
# ==========================================

# 1. Infrastructure
# -----------------
# Tailscale Auth Key (Optional, for remote access)
TAILSCALE_AUTH_KEY=tskey-auth-xxxx

# Database & Redis (Defaults usually work for Docker)
DATABASE_URL=postgresql+asyncpg://nexus:nexus_password@postgres:5432/nexus_db
REDIS_URL=redis://redis:6379/0

# 2. LLM Configuration (Ollama / OpenAI / VLLM)
# ---------------------------------------------
# Provider: 'ollama', 'openai', or 'vllm'
LLM_API_KEY=ollama
# URL for the LLM API (e.g., http://host.docker.internal:11434/v1 for local Ollama)
LLM_BASE_URL=http://host.docker.internal:11434/v1
# Model Name (e.g., qwen2.5:14b, gpt-4o)
LLM_MODEL=glm4.7-flash-32k

# 3. Embedding Configuration (RAG)
# --------------------------------
# Recommended: specific Ollama model like bge-m3 (1024 dim) or nomic-embed-text (768 dim)
EMBEDDING_API_KEY=ollama
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_MODEL=bge-m3:latest
EMBEDDING_DIMENSION=1024

# 4. Voice Configuration (STT/TTS)
# --------------------------------
STT_BASE_URL=http://host.docker.internal:9191/v1
STT_API_KEY=sk-local-test

# 5. Integrations & Channels
# --------------------------

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Telegram bot username, without the leading @
TELEGRAM_BOT_USERNAME=nexus_test_bot
# Comma-separated list of User IDs allowed to interact with the bot
TELEGRAM_ALLOWED_USERS=123456789,987654321
# Optional Proxy
TELEGRAM_PROXY_URL=http://192.168.1.100:7890

# Home Assistant
HOMEASSISTANT_URL=http://192.168.1.100:8123
HOMEASSISTANT_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Feishu / Lark (Official MCP)
# App ID (e.g., cli_a1b2c3d4e5f6)
FEISHU_APP_ID=cli_xxxxxxxxxxxx
# App Secret
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# WeChat / OpenClaw iLink Bot
# Set to true to enable the WeChat polling adapter
WECHAT_ENABLED=false
# Optional: preconfigured bot token. If omitted, Nexus will start a QR login flow in logs.
WECHAT_BOT_TOKEN=
# Optional: resume a pending QR code login flow if you already have the qrcode value
WECHAT_BOT_QRCODE=
# iLink API base URL
WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
# Protocol version from the OpenClaw reference implementation
WECHAT_CHANNEL_VERSION=1.0.2
# Poll interval between getupdates requests
WECHAT_POLL_INTERVAL_SECONDS=1.0

# 6. Initial Admin Provisioning
# ---------------------------
# If no users exist on first startup, an admin user will be created.
# Credentials will be displayed in the startup logs.
# You can recover or reset keys using: python scripts/admin/manage_user.py --list
INITIAL_ADMIN_USERNAME=admin

# 7. Security
# --------------------------
# JWT secret for web/API auth
JWT_SECRET=change-me-to-a-long-random-secret
# Master key for encrypting sensitive data in the database (AES-256)
# Generate a new one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NEXUS_MASTER_KEY=your_generated_fernet_key_here=
